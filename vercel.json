{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/ask",     "dest": "/api/ask.py"     },
    { "src": "/api/summary", "dest": "/api/summary.py" },
    { "src": "/api/quiz",    "dest": "/api/quiz.py"    },
    { "src": "/(.*)",        "dest": "/public/$1"      }
  ]
}
